---
import { getCollection, render } from 'astro:content';
import DirectAnswer from '../../components/DirectAnswer.astro';
import FAQBlock from '../../components/FAQBlock.astro';
import Footer from '../../components/Footer.astro';
import GuideCard from '../../components/GuideCard.astro';
import Header from '../../components/Header.astro';
import RelatedApps from '../../components/RelatedApps.astro';
import Layout from '../../layouts/Layout.astro';
import { breadcrumbSchema, faqsToSchema, hubFaqs, itemListSchema, parentSafetyFaqs, siteFaqs } from '../../lib/aeo';
import { sortApps } from '../../lib/catalog';

const allApps = (await getCollection('apps')).sort(sortApps);
const allGuides = await getCollection('guides');

export async function getStaticPaths() {
	const guides = await getCollection('guides');
	return guides.map((guide) => ({
		params: { slug: guide.id },
		props: { guide },
	}));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
const fallbackFaqs = guide.data.category === 'privacy' ? parentSafetyFaqs : siteFaqs;
const faqs = hubFaqs[guide.id] ?? fallbackFaqs;
const relatedApps = guide.data.relatedApps
	.map((id) => allApps.find((app) => app.id === id))
	.filter(Boolean);
const relatedGuides = guide.data.relatedGuides
	.map((id) => allGuides.find((entry) => entry.id === id))
	.filter(Boolean);
const pageUrl = new URL(Astro.url.pathname, Astro.site);
const schema = [
	{
		'@type': 'Article',
		'@id': `${pageUrl.href}#article`,
		headline: guide.data.title,
		description: guide.data.summary,
		image: new URL(guide.data.heroImage, Astro.site).href,
		dateModified: '2026-06-04',
		author: {
			'@type': 'Organization',
			name: 'NUC7 Studios',
		},
		publisher: {
			'@type': 'Organization',
			name: 'NUC7 Studios',
		},
		mainEntityOfPage: pageUrl.href,
	},
	breadcrumbSchema(
		[
			{ name: 'Home', href: '/' },
			{ name: 'Guides', href: '/guides/' },
			{ name: guide.data.title, href: `/guides/${guide.id}/` },
		],
		pageUrl,
	),
	itemListSchema(
		relatedApps.map((app) => ({
			title: app.data.title,
			href: `/apps/${app.id}/`,
		})),
		pageUrl,
	),
	faqsToSchema(faqs, pageUrl),
];
---

<Layout title={guide.data.title} description={guide.data.summary} image={guide.data.heroImage} schema={schema}>
	<Header />
	<main>
		<section class="section">
			<div class="shell hero-grid">
				<div class="hero-copy">
					<span class="eyebrow">{guide.data.eyebrow}</span>
					<h1 class="section-title">{guide.data.title}</h1>
					<p class="section-copy">{guide.data.summary}</p>
					<DirectAnswer answer={guide.data.directAnswer} points={guide.data.answerPoints} />
				</div>

				<div class="hero-visual">
					<div class="hero-image-frame compact">
						<img src={guide.data.heroImage} alt={guide.data.title} />
					</div>
				</div>
			</div>
		</section>

		<section class="section tone-paper">
			<div class="shell split-grid">
				<article class="info-card page-prose">
					{guide.data.ageRange && <p><strong>Age range:</strong> {guide.data.ageRange}</p>}
					{guide.data.lastReviewed && <p><strong>Last reviewed:</strong> {guide.data.lastReviewed}</p>}
					<Content />
				</article>

				<aside class="info-card">
					<h3>Search questions covered</h3>
					<ul class="answer-points">
						{guide.data.searchIntents.map((intent) => <li>{intent}</li>)}
					</ul>
				</aside>
			</div>
		</section>

		<section class="section">
			<div class="shell">
				<RelatedApps apps={relatedApps} />
			</div>
		</section>

		<section class="section tone-paper">
			<div class="shell">
				<FAQBlock faqs={faqs} />
			</div>
		</section>

		{relatedGuides.length > 0 && (
			<section class="section">
				<div class="shell">
					<span class="eyebrow">More Answers</span>
					<h2 class="section-title">Related parent guides.</h2>
					<div class="guide-grid" style="margin-top: 1.5rem;">
						{relatedGuides.map((entry) => (
							<GuideCard
								href={`/guides/${entry.id}/`}
								title={entry.data.title}
								summary={entry.data.summary}
								label={entry.data.eyebrow}
							/>
						))}
					</div>
				</div>
			</section>
		)}
	</main>
	<Footer />
</Layout>
