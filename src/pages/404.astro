---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found" description="The page you were looking for is not here.">
	<Header />
	<main>
		<section class="section">
			<div class="shell">
				<span class="eyebrow">404</span>
				<h1 class="section-title">That page wandered off.</h1>
				<p class="section-copy">
					The route may have moved during the NUC7 Studios rebuild. The app catalog and privacy
					policies are the best places to start again.
				</p>
				<div class="hero-actions">
					<a class="button" href="/apps/">Browse apps</a>
					<a class="button alt" href="/privacy-policies/">Open privacy policies</a>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>
