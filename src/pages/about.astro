---
import { getEntry, render } from 'astro:content';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';

const about = await getEntry('pages', 'about');
if (!about) {
	throw new Error('About page content is missing.');
}
const { Content } = await render(about);
---

<Layout title={about.data.title} description={about.data.summary}>
	<Header />
	<main>
		<section class="section">
			<div class="shell">
				<span class="eyebrow">About</span>
				<h1 class="section-title">{about.data.title}</h1>
				<p class="section-copy">{about.data.summary}</p>
			</div>
		</section>

		<section class="section tone-paper">
			<div class="shell">
				<article class="info-card page-prose">
					<Content />
				</article>
			</div>
		</section>
	</main>
	<Footer />
</Layout>
