---
const pathname = Astro.url.pathname;

const links = [
	{ href: '/', label: 'Home' },
	{ href: '/for-parents/', label: 'Parents' },
	{ href: '/apps/', label: 'Apps' },
	{ href: '/apps/kids/', label: 'Kids' },
	{ href: '/apps/parent-productivity/', label: 'Parent Productivity' },
	{ href: '/guides/', label: 'Guides' },
	{ href: '/comparisons/', label: 'Compare' },
	{ href: '/tools/ai-strong-password-generator/', label: 'Tools' },
	{ href: '/about/', label: 'About' },
	{ href: '/contact/', label: 'Contact' },
];
---

<header class="site-header">
	<div class="shell header-row">
		<a class="brand" href="/" data-stats-event="nav-home-click">
			<span class="brand-mark">N7</span>
			<span class="brand-copy">
				<strong>NUC7 Studios</strong>
				<span>Home-schooling and productivity apps</span>
			</span>
		</a>

		<nav class="nav-links" aria-label="Primary">
			{
				links.map((link) => (
					<a
						href={link.href}
						aria-current={pathname === link.href ? 'page' : undefined}
						data-stats-event={`nav-${link.label.toLowerCase()}-click`}
					>
						{link.label}
					</a>
				))
			}
		</nav>
	</div>
</header>
