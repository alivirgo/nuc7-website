---
export interface FAQ {
	question: string;
	answer: string;
}

interface Props {
	title?: string;
	intro?: string;
	faqs: FAQ[];
}

const {
	title = 'Questions parents often ask',
	intro = 'Short, practical answers for choosing the right app and using it well at home.',
	faqs,
} = Astro.props;
---

{faqs.length > 0 && (
	<section class="faq-block">
		<div class="faq-heading">
			<span class="eyebrow">FAQs</span>
			<h2 class="section-title">{title}</h2>
			<p class="section-copy">{intro}</p>
		</div>

		<div class="faq-list">
			{faqs.map((faq) => (
				<details class="faq-item">
					<summary>{faq.question}</summary>
					<p>{faq.answer}</p>
				</details>
			))}
		</div>
	</section>
)}
